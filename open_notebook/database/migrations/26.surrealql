-- Migration 26: Analysis cache table for bank statement and mobile CDR analysis
-- Stores pipeline results to avoid re-running expensive OCR/analysis

DEFINE TABLE analysis_cache SCHEMAFULL;
DEFINE FIELD source_id     ON TABLE analysis_cache TYPE string;
DEFINE FIELD analysis_type ON TABLE analysis_cache TYPE string;
DEFINE FIELD result        ON TABLE analysis_cache TYPE any;
DEFINE FIELD created       ON TABLE analysis_cache TYPE datetime DEFAULT time::now();
DEFINE INDEX idx_ac_source_type ON TABLE analysis_cache COLUMNS source_id, analysis_type UNIQUE;
